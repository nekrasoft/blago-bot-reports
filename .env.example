# Платформа: telegram (по умолчанию) или max
BOT_PLATFORM=telegram

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# MAX
MAX_BOT_TOKEN=your_max_bot_token
# ID групп через запятую; если пусто — без ограничений
ALLOWED_CHAT_IDS=

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Google Sheets
GOOGLE_SHEET_URL=полный_url_таблицы_из_браузера
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json

# MySQL с таблицами tbank-service; нужен для сохранения путевых листов
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=tbank_service
MYSQL_PASSWORD=
MYSQL_DATABASE=tbank_invoicing
WAYBILL_MAX_FILE_SIZE_BYTES=10485760

# Карта бункеров (опционально)
MAP_SERVICE_URL=https://example.com
# API-ключ для записи в карту (если карта требует авторизацию — задать MAP_BOT_API_KEY в .env карты и здесь тот же ключ)
MAP_BOT_API_KEY=
